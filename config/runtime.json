    "workflowEnvelope": {
      "name": "CI",
      "on": {
        "push": {
          "branches": ["main"]
        },
        "pull_request": null,
        "repository_dispatch": {
          "types": ["post-controlled-auto-merge-ci"]
        }
      },
      "permissions": {
        "contents": "read"
      },
      "concurrency": {
        "group": "ci-${{ github.workflow }}-${{ github.event_name == 'repository_dispatch' && github.run_id || github.ref }}",
        "cancel-in-progress": true
      }
    },
    "setupNodeCount": 3,
    "pnpmSetupCount": 1,
    "contextJob": {
      "job": "context",
      "stepCount": 3,
      "envelope": {
        "env": {
          "BASH_ENV": "",
          "NODE_OPTIONS": ""
        },
        "name": "context · resolve trusted verification commit",
        "outputs": {
          "baseline_ref": "${{ steps.resolve.outputs.baseline_ref }}",
          "checkout_ref": "${{ steps.resolve.outputs.checkout_ref }}"
        },
        "permissions": {
          "contents": "read"
        },
        "runs-on": "ubuntu-latest"
      },
      "checkout": {
        "name": "Check out the event-defined trusted commit",
        "with": {
          "fetch-depth": 0,
          "persist-credentials": false,
          "ref": "${{ github.sha }}"
        }
      },
      "runtime": {
        "with": {
          "node-version": "24.18.0",
          "package-manager-cache": false
        }
      },
      "resolver": {
        "envelope": {
          "env": {
            "CLIENT_MERGE_SHA": "${{ github.event.client_payload.merge_sha }}",
            "CLIENT_PR_NUMBER": "${{ github.event.client_payload.pr_number }}",
            "CLIENT_REVIEWED_HEAD_SHA": "${{ github.event.client_payload.reviewed_head_sha }}",
            "DEFAULT_BRANCH": "${{ github.event.repository.default_branch }}",
            "DISPATCH_ACTION": "${{ github.event.action }}",
            "EVENT_BEFORE_SHA": "${{ github.event.before }}",
            "EVENT_NAME": "${{ github.event_name }}",
            "EVENT_PULL_REQUEST_BASE_SHA": "${{ github.event.pull_request.base.sha }}",
            "EVENT_SHA": "${{ github.sha }}",
            "GH_TOKEN": "${{ github.token }}",
            "REPOSITORY": "${{ github.repository }}"
          },
          "id": "resolve",
          "name": "Resolve the exact verification commit",
          "shell": "bash"
        },
        "runSha256": "5fbec89e817d868f7dc4640190308d2412af058bdc7bdc7ce13ba08042bb4abd"
      }
    },
    "workspaceJob": {
      "job": "workspace",
      "envelope": {
        "env": {
          "BASH_ENV": "",
          "NODE_OPTIONS": ""
        },
        "name": "workspace · install · typecheck · lint · tests · build",
        "needs": "context",
        "runs-on": "ubuntu-latest"
      }
    },
    "bootstrapStep": {
      "job": "workspace",
      "name": "Bootstrap runtime contract parser",
      "id": "runtime_bootstrap",
      "condition": null,
      "continueOnError": true,
      "shell": "bash",
      "runLines": [
        "mkdir -p ci-artifacts",
        "set -euo pipefail",
        "parser_dir=\"$RUNNER_TEMP/runtime-contract-parser\"",
        "user_config=\"$RUNNER_TEMP/runtime-npm-userconfig\"",
        "global_config=\"$RUNNER_TEMP/runtime-npm-globalconfig\"",
        "test ! -e \"$parser_dir\"",
        "mkdir -p \"$parser_dir\"",
        ": > \"$user_config\"",
        ": > \"$global_config\"",
        "export NPM_CONFIG_AUDIT=false",
        "export NPM_CONFIG_FUND=false",
        "export NPM_CONFIG_GLOBALCONFIG=\"$global_config\"",
        "export NPM_CONFIG_IGNORE_SCRIPTS=true",
        "export NPM_CONFIG_REGISTRY=https://registry.npmjs.org/",
        "export NPM_CONFIG_USERCONFIG=\"$user_config\"",
        "pack_json=$(cd \"$parser_dir\" && npm pack yaml@2.9.0 --json 2>&1)",
        "filename=$(printf '%s\\n' \"$pack_json\" | jq -er 'if length == 1 then .[0].filename else empty end')",
        "integrity=$(printf '%s\\n' \"$pack_json\" | jq -er 'if length == 1 then .[0].integrity else empty end')",
        "test \"$integrity\" = \"sha512-2AvhNX3mb8zd6Zy7INTtSpl1F15HW6Wnqj0srWlkKLcpYl/gMIMJiyuGq2KeI2YFxUPjdlB+3Lc10seMLtL4cA==\"",
        "jq -cn --arg filename \"$filename\" --arg integrity \"$integrity\" '{filename: $filename, integrity: $integrity}' | tee ci-artifacts/runtime-bootstrap.log",
        "tar -xzf \"$parser_dir/$filename\" -C \"$parser_dir\"",
        "test -f \"$parser_dir/package/dist/index.js\""
      ]
    },
    "runtimeStep": {
      "job": "workspace",
      "name": "Runtime contract",
      "id": "runtime_contract",
      "condition": "always() && steps.runtime_bootstrap.outcome == 'success'",
      "continueOnError": true,
      "shell": "bash",
      "env": {
        "RUNTIME_YAML_MODULE": "${{ runner.temp }}/runtime-contract-parser/package/dist/index.js"
      },
      "command": "node scripts/ci/check-runtime-contract.mjs --verify-active && node tests/ci/runtime-contract.test.mjs"
    },
    "enforcementStep": {
      "job": "workspace",
      "name": "Enforce workspace results",
      "condition": "always()",
      "continueOnError": null,
      "shell": "bash",
      "env": {
        "RUNTIME_BOOTSTRAP": "${{ steps.runtime_bootstrap.outcome }}",
        "RUNTIME_CONTRACT": "${{ steps.runtime_contract.outcome }}",
        "INSTALL": "${{ steps.install.outcome }}",
        "DEPENDENCY_SECURITY": "${{ steps.dependency_security.outcome }}",
        "TYPECHECK": "${{ steps.typecheck.outcome }}",
        "LINT": "${{ steps.lint.outcome }}",
        "FORMAT": "${{ steps.format.outcome }}",
        "UNIT_TESTS": "${{ steps.unit_tests.outcome }}",
        "BROWSER_INSTALL": "${{ steps.browser_install.outcome }}",
        "ACCESSIBILITY_BASELINE": "${{ steps.accessibility_baseline.outcome }}",
        "BROWSER_TESTS": "${{ steps.browser_tests.outcome }}",
        "BUILD": "${{ steps.build.outcome }}",
        "PRODUCTION_SMOKE": "${{ steps.production_smoke.outcome }}"
      },
      "requiredStages": [
        "RUNTIME_BOOTSTRAP",
        "RUNTIME_CONTRACT",
        "INSTALL",
        "DEPENDENCY_SECURITY",
        "TYPECHECK",
        "LINT",
        "FORMAT",
        "UNIT_TESTS",
        "BUILD",
        "BROWSER_INSTALL",
        "ACCESSIBILITY_BASELINE",
        "BROWSER_TESTS",
        "PRODUCTION_SMOKE"
      ],
      "runLines": [
        "failed=0",
        "for stage in RUNTIME_BOOTSTRAP RUNTIME_CONTRACT INSTALL DEPENDENCY_SECURITY TYPECHECK LINT FORMAT UNIT_TESTS BUILD BROWSER_INSTALL ACCESSIBILITY_BASELINE BROWSER_TESTS PRODUCTION_SMOKE; do",
        "  value=\"${!stage}\"",
        "  printf '%s=%s\\n' \"$stage\" \"$value\"",
        "  if [ \"$value\" != \"success\" ]; then",
        "    failed=1",
        "  fi",
        "done",
        "exit \"$failed\""
      ]
    }
