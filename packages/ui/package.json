{
  "name": "@minniewinnie/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "tailwind.config.ts",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./tokens/*": {
      "types": "./src/tokens/*.ts",
      "default": "./src/tokens/*.ts"
    },
    "./themes": {
      "types": "./src/themes/index.ts",
      "default": "./src/themes/index.ts"
    },
    "./themes/*": {
      "types": "./src/themes/*.ts",
      "default": "./src/themes/*.ts"
    },
    "./providers": {
      "types": "./src/providers/index.ts",
      "default": "./src/providers/index.ts"
    },
    "./providers/*": {
      "types": "./src/providers/*.tsx",
      "default": "./src/providers/*.tsx"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*/index.tsx",
      "default": "./src/components/*/index.tsx"
    },
    "./styles/base.css": "./src/styles/base.css",
    "./tailwind": "./tailwind.config.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:types": "tsc --emitDeclarationOnly --declaration --declarationDir dist/types",
    "build:js": "rollup -c --bundleConfigAsCjs",
    "build": "pnpm build:types && pnpm build:js",
    "dev": "rollup -c -w --bundleConfigAsCjs",
    "lint": "eslint src rollup.config.js",
    "test": "vitest run --root ../.. packages/ui"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.16",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rollup": "^4.62.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-postcss": "^4.0.2",
    "tailwindcss": "^3.4.19"
  }
}
