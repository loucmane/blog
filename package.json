{
  "name": "minniewinnie-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": ">=11.11.0 <12"
  },
  "scripts": {
    "dev": "pnpm --parallel dev",
    "build": "pnpm -r build",
    "test": "vitest run --reporter=default --reporter=json --outputFile.json=ci-artifacts/vitest-results.json && node scripts/ci/check-test-results.mjs unit ci-artifacts/vitest-results.json",
    "test:coverage": "vitest run --coverage --reporter=default --reporter=json --outputFile.json=ci-artifacts/vitest-results.json && node scripts/ci/check-test-results.mjs unit ci-artifacts/vitest-results.json",
    "test:browser": "playwright test && node scripts/ci/check-test-results.mjs browser ci-artifacts/playwright-results.json",
    "test:browser:install": "playwright install --with-deps chromium",
    "test:quality-contract": "node --test tests/ci/accessibility-baseline.test.mjs tests/ci/eslint-contract.test.mjs tests/ci/test-capability.test.mjs tests/ci/test-results.test.mjs",
    "test:security-hotfix": "node --test tests/ci/security-hotfix.test.mjs",
    "test:smoke:web": "node scripts/ci/web-production-smoke.mjs",
    "lint": "eslint packages scripts/ci/check-accessibility-baseline.mjs scripts/ci/check-test-capability.mjs scripts/ci/check-test-results.mjs tests/ci/accessibility-baseline.test.mjs tests/ci/eslint-contract.test.mjs tests/ci/runtime-contract.test.mjs tests/ci/security-hotfix.test.mjs tests/ci/test-capability.test.mjs tests/ci/test-results.test.mjs tests/e2e eslint.config.mjs prettier.config.mjs vitest.config.ts playwright.config.ts --max-warnings 0",
    "format": "prettier --write package.json 'packages/**/*.{js,mjs,cjs,ts,tsx,json,css,md}' 'tests/ci/{accessibility-baseline,eslint-contract,runtime-contract,security-hotfix,test-capability,test-results}.test.mjs' 'tests/e2e/**/*.{ts,json}' 'tests/setup/**/*.ts' 'scripts/ci/check-{accessibility-baseline,test-capability,test-results}.mjs' config/ci/verification-capabilities.json config/runtime.json '*.{config.mjs,config.ts}' 'tsconfig*.json'",
    "format:check": "prettier --check package.json 'packages/**/*.{js,mjs,cjs,ts,tsx,json,css,md}' 'tests/ci/{accessibility-baseline,eslint-contract,runtime-contract,security-hotfix,test-capability,test-results}.test.mjs' 'tests/e2e/**/*.{ts,json}' 'tests/setup/**/*.ts' 'scripts/ci/check-{accessibility-baseline,test-capability,test-results}.mjs' config/ci/verification-capabilities.json config/runtime.json '*.{config.mjs,config.ts}' 'tsconfig*.json'",
    "typecheck": "pnpm --filter @minniewinnie/ui run build:types && pnpm --filter web run typecheck && tsc --project tsconfig.test.json --noEmit",
    "security:audit": "node scripts/ci/check-dependency-security.mjs",
    "test:capability": "node scripts/ci/check-test-capability.mjs",
    "ci:taskmaster": "node scripts/ci/check-taskmaster.mjs",
    "ci:aegis": "python3 scripts/ci/check-aegis.py",
    "ci:guard": "python3 scripts/ci/check-legacy-guard.py",
    "ci:auto-merge-policy": "node tests/ci/auto-merge-policy.test.mjs && node tests/ci/auto-merge-workflow.test.mjs",
    "ci:agent-skills": "node scripts/agent-skills/validate-platform.mjs && node --test tests/agent-skills/*.test.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@eslint-react/eslint-plugin": "5.9.5",
    "@next/eslint-plugin-next": "16.2.10",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y-x": "0.2.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  },
  "dependencies": {
    "framer-motion": "^12.15.0"
  }
}
