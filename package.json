{
  "name": "minniewinnie-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:smart": "node ./scripts/dev-orchestrator.js",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "worktree:dev": "./scripts/worktree-smart-tmux.sh",
    "worktree:list": "git worktree list",
    "worktree:clean": "git worktree list | grep -E '\\.worktrees/' | awk '{print $1}' | xargs -I {} git worktree remove {} --force"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  },
  "dependencies": {
    "framer-motion": "^12.15.0"
  }
}