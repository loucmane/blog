  "transitions": {
    "1to2": {
      "trigger": "phase1Complete",
      "data": ["conventions", "patterns"],
      "validation": ["conventionsFound > 0", "patternsIdentified > 0"]
    },
    "2to3": {
      "trigger": "phase2Complete",
      "data": ["synthesized", "relationships"],
      "validation": ["synthesisComplete", "relationshipsMapped"]
    },
    "3to4": {
      "trigger": "phase3Complete",
      "data": ["documents", "structure"],
      "validation": ["documentsGenerated > 0"]
    },
    "4to5": {
      "trigger": "phase4Complete",
      "data": ["validation", "corrections"],
      "validation": ["qualityScore >= 0.8"]
    }
