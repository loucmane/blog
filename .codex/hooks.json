{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "AEGIS_INVOKING_AGENT=codex \"$(git rev-parse --show-toplevel)/.aegis/bin/aegis\" hook posttooluse",
            "statusMessage": "Recording Aegis tracking",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": "AEGIS_INVOKING_AGENT=codex \"$(git rev-parse --show-toplevel)/.aegis/bin/aegis\" hook record",
            "statusMessage": "Recording Aegis evidence",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "^(Bash|apply_patch|mcp__.*)$"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "AEGIS_INVOKING_AGENT=codex \"$(git rev-parse --show-toplevel)/.aegis/bin/aegis\" hook pretooluse",
            "statusMessage": "Evaluating Aegis policy",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "^(Bash|apply_patch|mcp__.*)$"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "AEGIS_INVOKING_AGENT=codex \"$(git rev-parse --show-toplevel)/.aegis/bin/aegis\" hook sessionstart",
            "statusMessage": "Loading Aegis brief and session evidence",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "AEGIS_INVOKING_AGENT=codex \"$(git rev-parse --show-toplevel)/.aegis/bin/aegis\" hook stop",
            "statusMessage": "Checking Aegis completion evidence",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "AEGIS_INVOKING_AGENT=codex \"$(git rev-parse --show-toplevel)/.aegis/bin/aegis\" hook subagentstart",
            "statusMessage": "Recording Aegis subagent start",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "AEGIS_INVOKING_AGENT=codex \"$(git rev-parse --show-toplevel)/.aegis/bin/aegis\" hook recordjson",
            "statusMessage": "Recording Aegis subagent completion",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ]
  }
}
