{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loucmane/blog/schemas/agent-skills/review-result.schema.json",
  "title": "Cross-Agent Skill Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reviewId",
    "skill",
    "mode",
    "verdict",
    "summary",
    "generatedAt",
    "headSha",
    "findings",
    "evidence"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "reviewId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "skill": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "mode": {
      "const": "advisory"
    },
    "verdict": {
      "enum": ["pass", "warn", "fail", "not-applicable"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "headSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "category",
          "message",
          "subjective",
          "blocking",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "severity": {
            "enum": ["info", "warning", "error"]
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "subjective": {
            "type": "boolean"
          },
          "blocking": {
            "type": "boolean"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path"],
        "properties": {
          "kind": {
            "enum": ["command", "file", "url"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
